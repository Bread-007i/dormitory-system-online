{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm install && npm run build 2>/dev/null || true"
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "unless_stopped",
    "restartPolicyMaxRetries": 10
  }
}
