# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=dormitory_system

# Connection Pool
DB_CONNECTION_LIMIT=10

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this

# PromptPay Payment Integration (Testing)
PROMPTPAY_ACCOUNT_NAME=Your Account Name
PROMPTPAY_ACCOUNT_MASK=xxx-x-x****-x

# Optional: Payment Verification (add if using payment verification)
# PAYMENT_VERIFY_WEBHOOK_SECRET=your_webhook_secret
